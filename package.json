{
    "name": "theframedwall",
    "version": "1.0.0",
    "private": true,
    "description": "TheFramedWall - Custom Print-on-Demand Platform",
    "scripts": {
        "dev:api": "pnpm --filter api dev",
        "dev:web": "pnpm --filter web dev",
        "dev:admin": "pnpm --filter admin dev",
        "dev": "concurrently \"pnpm dev:api\" \"pnpm dev:web\" \"pnpm dev:admin\"",
        "db:migrate": "pnpm --filter api prisma migrate dev",
        "db:studio": "pnpm --filter api prisma studio"
    },
    "devDependencies": {
        "@prisma/client": "^6.19.2",
        "ag-psd": "^30.1.0",
        "canvas": "^3.2.1",
        "concurrently": "^8.2.2",
        "prisma": "^6.19.2",
        "sharp": "^0.34.5"
    },
    "packageManager": "pnpm@10.31.0",
    "pnpm": {
        "onlyBuiltDependencies": [
            "@nestjs/core",
            "@prisma/engines",
            "prisma",
            "@prisma/client",
            "esbuild",
            "sharp",
            "unrs-resolver",
            "canvas"
        ],
        "ignoredBuiltDependencies": [
            "@nestjs/core",
            "@prisma/engines",
            "prisma"
        ]
    }
}
