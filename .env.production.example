# ─────────────────────────────────────
# TFW Production Environment Variables
# Copy to .env.production and fill in
# ─────────────────────────────────────

# ── Database ──
DB_USER=tfw
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=tfw_db
DATABASE_URL=postgresql://tfw:CHANGE_ME_STRONG_PASSWORD@postgres:5432/tfw_db

# ── Auth ──
JWT_SECRET=CHANGE_ME_RANDOM_64_CHAR_STRING

# ── Server ──
API_PORT=5000
CLIENT_URL=https://theframedwall.com

# ── Razorpay ──
RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXX

# ── SMTP (Hostinger) ──
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=no-reply@theframedwall.com
SMTP_PASS=YOUR_EMAIL_PASSWORD
SMTP_FROM=TheFramedWall <no-reply@theframedwall.com>
ADMIN_EMAIL=theframedwall@gmail.com
