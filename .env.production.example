;# ─────────────────────────────────────
# TFW Production Environment Variables
# Copy to .env.production and fill in
# ─────────────────────────────────────

# ── Database ──
DB_USER=tfw
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=tfw_db
DATABASE_URL=postgresql://tfw:CHANGE_ME_STRONG_PASSWORD@postgres:5432/tfw_db

# ── Auth ──
JWT_SECRET=CHANGE_ME_RANDOM_64_CHAR_STRING

# ── Server ──
API_PORT=5000
CLIENT_URL=https://theframedwall.com

# ── Razorpay ──
RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXX

# ── SMTP (Hostinger) ──
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=no-reply@theframedwall.com
SMTP_PASS=YOUR_EMAIL_PASSWORD
SMTP_FROM=TheFramedWall <no-reply@theframedwall.com>
ADMIN_EMAIL=theframedwall@gmail.com

# ── SMS — MSG91 ──
# Get Auth Key from: msg91.com → API → Auth Key
SMS_PROVIDER=msg91
MSG91_AUTH_KEY=YOUR_24_CHAR_AUTH_KEY
# DLT-approved OTP template. Content must include ##OTP##
# e.g. "Your TheFramedWall OTP is ##OTP##. Valid for 5 min. Do not share."
MSG91_OTP_TEMPLATE_ID=YOUR_TEMPLATE_ID
MSG91_SENDER_ID=TFWALL
# Transactional template for back-in-stock alerts (optional)
MSG91_BIS_TEMPLATE_ID=YOUR_BIS_TEMPLATE_ID

# ── Shipping Carriers ──
# Default pickup pincode used when no per-carrier source_pincode is set in DB
PICKUP_PINCODE=411001

# Shiprocket (https://app.shiprocket.in → Settings → API)
SHIPROCKET_EMAIL=your@email.com
SHIPROCKET_PASSWORD=YOUR_SHIPROCKET_PASSWORD

# Delhivery (https://app.delhivery.com → Waybill → API Integration)
DELHIVERY_API_KEY=YOUR_DELHIVERY_TOKEN

# Blue Dart (Enterprise contract required — https://developer.bluedart.com)
BLUEDART_API_KEY=YOUR_BLUEDART_LICENSE_KEY
BLUEDART_LICENSE_ID=YOUR_BLUEDART_CLIENT_ID

# DTDC (Enterprise contract — https://blktapi.dtdc.com)
DTDC_API_KEY=YOUR_DTDC_API_KEY
DTDC_CUSTOMER_ID=YOUR_DTDC_CUSTOMER_CODE

# ── Hyperlocal Delivery ──
# Dunzo (enterprise account: dunzo.com → API)
DUNZO_CLIENT_ID=YOUR_DUNZO_CLIENT_ID
DUNZO_API_KEY=YOUR_DUNZO_CLIENT_SECRET
# Porter (business account: porter.in → API)
PORTER_API_KEY=YOUR_PORTER_BEARER_TOKEN
